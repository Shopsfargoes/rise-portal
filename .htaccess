# ============================================================
# RISE CAPITAL GROUP — Apache Configuration
# Place this file as .htaccess inside the /public directory
# ============================================================

Options -Indexes
Options -MultiViews

RewriteEngine On

# Skip rewrite for actual files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Skip rewrite for .php files that exist (direct PHP access)
RewriteCond %{REQUEST_URI} \.php$
RewriteRule ^ - [L]

# Route everything else through index.php
RewriteRule ^ index.php [QSA,L]

# Block hidden files (.env, .git, etc.)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block PHP execution in uploads folder
<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#/assets/uploads/#">
        Order allow,deny
        Deny from all
    </If>
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/webp             "access plus 1 year"
</IfModule>

# Compress responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>